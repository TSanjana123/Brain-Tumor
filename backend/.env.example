# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/brain_tumor

# Frontend URL allowed by CORS
FRONTEND_URL=http://localhost:3000

# JWT signing secret (generate a long random string)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# Google Gemini API key for the chat assistant
GEMINI_API_KEY=

# Node server port (default 5001)
PORT=5001

# Optional: override the default DenseNet weights location (used by app.py)
# MODEL_PATH=/absolute/path/to/densenet_201_brain_tumor.pth
